# ─────────────────────────────────────────────────────────────
# Firebase WEB app config (public — identifies the project only).
# Firebase Console → ⚙️ Project settings → General → "Your apps"
#   → Web app (</> icon) → SDK setup and configuration → Config
# Copy this file to ".env" and paste the values in.
#
# Leave VITE_FIREBASE_API_KEY blank to run in keyless guest mode
# (no login screen, local JSON storage).
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=sustainable-waste-manage-2eadb.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=sustainable-waste-manage-2eadb
VITE_FIREBASE_STORAGE_BUCKET=sustainable-waste-manage-2eadb.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
